<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.andrei.sample_project.AuthorEditController"
            prefHeight="700.0" prefWidth="1000.0"
            style="-fx-background-color: linear-gradient(to bottom right, #f5f7fa, #e8ecf3);">


    <top>
        <HBox alignment="CENTER_LEFT" spacing="15"
              style="-fx-background-color: linear-gradient(to right, #667eea, #764ba2); -fx-padding: 15 25;">

            <Button text="← Back" onAction="#onBackClick"
                    style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 8 15;"/>

            <Label fx:id="titleLabel" text="✍ Edit Author"
                   style="-fx-text-fill: white; -fx-font-size: 20; -fx-font-weight: bold;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="💾 Save" onAction="#onSaveClick"
                    style="-fx-background-color: #27ae60; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 8 15;"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox spacing="25" style="-fx-padding: 30;">

                <GridPane style="-fx-padding: 25; -fx-background-color: white; -fx-background-radius: 15;"
                          hgap="20" vgap="15">

                    <columnConstraints>
                        <ColumnConstraints percentWidth="40"/>
                        <ColumnConstraints percentWidth="60"/>
                    </columnConstraints>


                    <VBox spacing="15" GridPane.columnIndex="0">
                        <Label text="Author Image" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #333;"/>

                        <VBox alignment="CENTER" spacing="10">

                            <ImageView fx:id="authorImageView" fitWidth="180" fitHeight="220" preserveRatio="true"
                                       style="-fx-background-radius: 10;">
                            </ImageView>


                            <StackPane fx:id="avatarStack" visible="false">
                                <Circle radius="60" style="-fx-fill: linear-gradient(to bottom, #667eea, #764ba2);"/>
                                <Label fx:id="avatarInitialsLabel" text="AA"
                                       style="-fx-text-fill: white; -fx-font-size: 36; -fx-font-weight: bold;"/>
                            </StackPane>


                            <HBox spacing="10" alignment="CENTER">
                                <Button text="📷 Upload" onAction="#onUploadImage"
                                        style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
                                <Button text="❌ Clear" onAction="#onClearImage"
                                        style="-fx-background-color: #e74c3c; -fx-text-fill: white;"/>
                            </HBox>
                            <Label fx:id="imagePathLabel" text="No image selected"
                                   style="-fx-text-fill: #888; -fx-font-size: 11;"/>
                        </VBox>


                        <VBox spacing="8" style="-fx-padding: 15; -fx-background-color: #f8f9fa; -fx-background-radius: 10;">
                            <Label text="📊 Author Stats" style="-fx-font-weight: bold; -fx-text-fill: #333;"/>
                            <Label fx:id="statsBookCountLabel" text="Books: 0" style="-fx-text-fill: #666;"/>
                            <Label fx:id="statsRatingLabel" text="Avg Rating: N/A" style="-fx-text-fill: #666;"/>
                        </VBox>
                    </VBox>


                    <VBox spacing="15" GridPane.columnIndex="1">
                        <Label text="Author Details" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #333;"/>


                        <VBox spacing="5">
                            <Label text="Full Name *" style="-fx-font-weight: bold; -fx-text-fill: #555;"/>
                            <TextField fx:id="nameField" promptText="Author's full name"
                                       style="-fx-background-radius: 5;"/>
                        </VBox>


                        <VBox spacing="5">
                            <Label text="Biography" style="-fx-font-weight: bold; -fx-text-fill: #555;"/>
                            <TextArea fx:id="biographyArea" promptText="Author biography..."
                                      wrapText="true" prefRowCount="5"
                                      style="-fx-background-radius: 5;"/>
                        </VBox>


                        <HBox spacing="15">
                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                <Label text="Birth Date" style="-fx-font-weight: bold; -fx-text-fill: #555;"/>
                                <DatePicker fx:id="birthDatePicker" promptText="Select date"
                                            style="-fx-background-radius: 5;"/>
                            </VBox>

                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                <Label text="Nationality" style="-fx-font-weight: bold; -fx-text-fill: #555;"/>
                                <TextField fx:id="nationalityField" promptText="e.g., British, American"
                                           style="-fx-background-radius: 5;"/>
                            </VBox>
                        </HBox>


                        <HBox spacing="15">
                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                <Label text="Death Date (if deceased)" style="-fx-font-weight: bold; -fx-text-fill: #555;"/>
                                <DatePicker fx:id="deathDatePicker" promptText="Select date"
                                            style="-fx-background-radius: 5;"/>
                            </VBox>

                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                <Label text="Website" style="-fx-font-weight: bold; -fx-text-fill: #555;"/>
                                <TextField fx:id="websiteField" promptText="https://example.com"
                                           style="-fx-background-radius: 5;"/>
                            </VBox>
                        </HBox>


                        <VBox spacing="5">
                            <Label text="Status" style="-fx-font-weight: bold; -fx-text-fill: #555;"/>
                            <ComboBox fx:id="statusComboBox" style="-fx-background-radius: 5;"/>
                        </VBox>
                    </VBox>
                </GridPane>


                <VBox spacing="15">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="📚 Author's Books"
                               style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="➕ Add Book" onAction="#onAddBookClick"
                                style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold;"/>
                    </HBox>


                    <TableView fx:id="booksTable" style="-fx-background-radius: 10; -fx-background-color: white;">
                        <columns>
                            <TableColumn fx:id="bookIdColumn" text="ID" prefWidth="50"/>
                            <TableColumn fx:id="bookTitleColumn" text="Title" prefWidth="250"/>
                            <TableColumn fx:id="bookYearColumn" text="Year" prefWidth="80"/>
                            <TableColumn fx:id="bookGenreColumn" text="Genre" prefWidth="120"/>
                            <TableColumn fx:id="bookRatingColumn" text="Rating" prefWidth="80"/>
                            <TableColumn fx:id="bookActionsColumn" text="Actions" prefWidth="150"/>
                        </columns>
                    </TableView>


                    <HBox alignment="CENTER" spacing="10">
                        <Button text="🗑 Delete Author" onAction="#onDeleteClick"
                                style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-font-weight: bold;
                                       -fx-padding: 10 20; -fx-font-size: 14;"/>
                    </HBox>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>