<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.andrei.sample_project.MainController"
            prefHeight="750.0" prefWidth="1250.0"
            style="-fx-background-color: linear-gradient(to bottom right, #f5e6ff, #e6f7ff);">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20.0"
              style="-fx-background-color: linear-gradient(to right, rgba(138, 127, 255, 0.95), rgba(106, 143, 255, 0.95));"
              prefHeight="70.0">

            <effect>
                <DropShadow radius="8" color="rgba(100, 130, 255, 0.3)" offsetX="0" offsetY="3"/>
            </effect>

            <padding>
                <Insets left="25.0" right="25.0"/>
            </padding>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="📚" style="-fx-font-size: 30;"/>
                <VBox spacing="2">
                    <Label fx:id="welcomeLabel" text="Welcome!"
                           style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 18;"/>
                    <Label fx:id="progressLabel" text="Select a book to update progress"
                           style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 11;"/>
                </VBox>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <HBox spacing="8" alignment="CENTER"
                  style="-fx-background-color: rgba(255,255,255,0.15); -fx-background-radius: 25; -fx-padding: 5 10;">

                <ComboBox fx:id="searchFilterCombo" prefWidth="105" prefHeight="32"
                          style="-fx-background-color: white; -fx-background-radius: 15; -fx-font-size: 11;">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="🔍 All"/>
                            <String fx:value="📚 Books"/>
                            <String fx:value="✍ Authors"/>
                            <String fx:value="👤 Users"/>
                        </FXCollections>
                    </items>
                    <value>
                        <String fx:value="🔍 All"/>
                    </value>
                </ComboBox>


                <TextField fx:id="searchField"
                           promptText="Search..."
                           prefWidth="250"
                           prefHeight="32"
                           onAction="#onSearchBooks"
                           style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 0 15;"/>

                <Button fx:id="searchButton"
                        text="🔍"
                        onAction="#onSearchBooks"
                        prefHeight="32" prefWidth="40"
                        style="-fx-background-color: white; -fx-text-fill: #667eea;
                               -fx-font-size: 14; -fx-background-radius: 15;"/>
            </HBox>


            <Button fx:id="menuButton"
                    text="☰"
                    onAction="#onMenuClick"
                    style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-font-size: 18;
                           -fx-background-radius: 20; -fx-min-width: 45; -fx-min-height: 45;"/>
        </HBox>
    </top>


    <center>
        <HBox spacing="20" style="-fx-padding: 20;">


            <VBox spacing="15" HBox.hgrow="ALWAYS">


                <HBox spacing="12" alignment="CENTER_LEFT"
                      style="-fx-padding: 12 18; -fx-background-color: white; -fx-background-radius: 12;">
                    <effect>
                        <DropShadow radius="3" color="rgba(0,0,0,0.08)" offsetY="2"/>
                    </effect>

                    <Label text="📖" style="-fx-font-size: 18;"/>
                    <Label text="Update Progress:" style="-fx-text-fill: #555; -fx-font-weight: bold;"/>

                    <TextField fx:id="pageNumberField"
                               promptText="Page #"
                               prefWidth="80"
                               disable="true"
                               style="-fx-background-radius: 8;"/>

                    <Button fx:id="updateProgressButton"
                            text="Update"
                            onAction="#onUpdateProgress"
                            prefWidth="90"
                            disable="true"
                            style="-fx-background-color: linear-gradient(to right, #667eea, #764ba2);
                                   -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;"/>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Label text="💡 Double-click any book for options"
                           style="-fx-text-fill: #aaa; -fx-font-size: 11; -fx-font-style: italic;"/>
                </HBox>


                <TabPane fx:id="tabPane" VBox.vgrow="ALWAYS"
                         tabClosingPolicy="UNAVAILABLE"
                         style="-fx-background-color: transparent;">


                    <Tab>
                        <graphic>
                            <HBox spacing="5" alignment="CENTER">
                                <Label text="📖" style="-fx-font-size: 14;"/>
                                <Label text="Reading" style="-fx-font-weight: bold;"/>
                            </HBox>
                        </graphic>
                        <content>
                            <VBox style="-fx-background-color: white; -fx-background-radius: 0 0 10 10; -fx-padding: 10;">
                                <TableView fx:id="readingTable" VBox.vgrow="ALWAYS"
                                           style="-fx-background-color: transparent; -fx-border-color: transparent;">
                                    <columns>
                                        <TableColumn fx:id="readingCoverCol" text="" prefWidth="55" sortable="false"/>
                                        <TableColumn fx:id="readingTitleCol" text="Title" prefWidth="220"/>
                                        <TableColumn fx:id="readingAuthorCol" text="Author" prefWidth="160"/>
                                        <TableColumn fx:id="readingGenreCol" text="Genre" prefWidth="100"/>
                                        <TableColumn fx:id="readingProgressCol" text="Progress" prefWidth="150"/>
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                    </columnResizePolicy>
                                </TableView>
                            </VBox>
                        </content>
                    </Tab>


                    <Tab>
                        <graphic>
                            <HBox spacing="5" alignment="CENTER">
                                <Label text="📚" style="-fx-font-size: 14;"/>
                                <Label text="To Read" style="-fx-font-weight: bold;"/>
                            </HBox>
                        </graphic>
                        <content>
                            <VBox style="-fx-background-color: white; -fx-background-radius: 0 0 10 10; -fx-padding: 10;">
                                <TableView fx:id="toReadTable" VBox.vgrow="ALWAYS"
                                           style="-fx-background-color: transparent; -fx-border-color: transparent;">
                                    <columns>
                                        <TableColumn fx:id="toReadCoverCol" text="" prefWidth="55" sortable="false"/>
                                        <TableColumn fx:id="toReadTitleCol" text="Title" prefWidth="220"/>
                                        <TableColumn fx:id="toReadAuthorCol" text="Author" prefWidth="160"/>
                                        <TableColumn fx:id="toReadGenreCol" text="Genre" prefWidth="100"/>
                                        <TableColumn fx:id="toReadRatingCol" text="Rating" prefWidth="80"/>
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                    </columnResizePolicy>
                                </TableView>
                            </VBox>
                        </content>
                    </Tab>
                    <Tab>
                        <graphic>
                            <HBox spacing="5" alignment="CENTER">
                                <Label text="✅" style="-fx-font-size: 14;"/>
                                <Label text="Completed" style="-fx-font-weight: bold;"/>
                            </HBox>
                        </graphic>
                        <content>
                            <VBox style="-fx-background-color: white; -fx-background-radius: 0 0 10 10; -fx-padding: 10;">
                                <TableView fx:id="completedTable" VBox.vgrow="ALWAYS"
                                           style="-fx-background-color: transparent; -fx-border-color: transparent;">
                                    <columns>
                                        <TableColumn fx:id="completedCoverCol" text="" prefWidth="55" sortable="false"/>
                                        <TableColumn fx:id="completedTitleCol" text="Title" prefWidth="220"/>
                                        <TableColumn fx:id="completedAuthorCol" text="Author" prefWidth="160"/>
                                        <TableColumn fx:id="completedGenreCol" text="Genre" prefWidth="100"/>
                                        <TableColumn fx:id="completedRatingCol" text="Rating" prefWidth="80"/>
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                    </columnResizePolicy>
                                </TableView>
                            </VBox>
                        </content>
                    </Tab>
                </TabPane>
            </VBox>


            <VBox spacing="15" prefWidth="280" minWidth="280">


                <VBox spacing="10"
                      style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 15;">
                    <effect>
                        <DropShadow radius="5" color="rgba(0,0,0,0.08)" offsetY="2"/>
                    </effect>

                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="🚀" style="-fx-font-size: 18;"/>
                        <Label text="Coming Soon"
                               style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                    </HBox>

                    <Separator/>


                    <VBox fx:id="comingSoonContainer" spacing="10">
                        <Label text="Loading..." style="-fx-text-fill: #999;"/>
                    </VBox>
                </VBox>


                <VBox spacing="10"
                      style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 15;">
                    <effect>
                        <DropShadow radius="5" color="rgba(0,0,0,0.08)" offsetY="2"/>
                    </effect>

                    <Label text="📊 Your Stats"
                           style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                    <Separator/>

                    <HBox spacing="15" alignment="CENTER">
                        <VBox alignment="CENTER" spacing="3">
                            <Label fx:id="statsReadingLabel" text="0"
                                   style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #667eea;"/>
                            <Label text="Reading" style="-fx-font-size: 10; -fx-text-fill: #888;"/>
                        </VBox>
                        <VBox alignment="CENTER" spacing="3">
                            <Label fx:id="statsToReadLabel" text="0"
                                   style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #764ba2;"/>
                            <Label text="To Read" style="-fx-font-size: 10; -fx-text-fill: #888;"/>
                        </VBox>
                        <VBox alignment="CENTER" spacing="3">
                            <Label fx:id="statsCompletedLabel" text="0"
                                   style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
                            <Label text="Done" style="-fx-font-size: 10; -fx-text-fill: #888;"/>
                        </VBox>
                    </HBox>
                </VBox>


                <VBox spacing="10"
                      style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 15;">
                    <effect>
                        <DropShadow radius="5" color="rgba(0,0,0,0.08)" offsetY="2"/>
                    </effect>

                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="⭐" style="-fx-font-size: 16;"/>
                        <Label text="Top Rated"
                               style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="viewAllTopRatedBtn" text="View All"
                                onAction="#onViewTopRated"
                                style="-fx-background-color: transparent; -fx-text-fill: #667eea;
                                       -fx-font-size: 11; -fx-cursor: hand;"/>
                    </HBox>

                    <VBox fx:id="topRatedContainer" spacing="8">

                    </VBox>
                </VBox>

            </VBox>
        </HBox>
    </center>

</BorderPane>
